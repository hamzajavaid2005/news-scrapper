generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Source {
  id            String   @id @default(uuid())
  name          String
  feedUrl       String   @unique
  baseUrl       String?
  active        Boolean  @default(true)
  lastCheckedAt DateTime @default(now())
  totalArticles Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  articles      Article[]

  @@map("sources")
}

model Article {
  id           String   @id @default(uuid())
  url          String   @unique
  title        String
  excerpt      String?
  textContent  String?
  byline       String?
  siteName     String?
  status       String   @default("pending") // pending, scraped, failed
  errorMessage String?
  discoveredAt DateTime @default(now())
  scrapedAt    DateTime?
  embedding    Unsupported("vector(1536)")?
  
  sourceId     String
  source       Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  generatedArticle GeneratedArticle?

  @@index([url])
  @@index([status])
  @@index([sourceId])
  @@map("articles")
}

model GeneratedArticle {
  id          String   @id @default(uuid())
  articleId   String   @unique
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  title       String         // AI-generated title
  content     String         // AI-generated content
  category    String         // e.g., "Politics", "Sports", "Tech", "Entertainment"
  
  status      String   @default("pending") // pending, generated, failed
  errorMessage String?
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relation to track which webhooks received this article
  webhookPublishes WebhookPublish[]
  
  @@index([category])
  @@index([status])
  @@index([generatedAt])
  @@map("generated_articles")
}

model Webhook {
  id          String   @id @default(uuid())
  name        String                          // e.g., "Production Blog", "Staging"
  url         String   @unique                // The webhook URL
  active      Boolean  @default(true)         // Enable/disable webhook
  secret      String?                         // Optional secret for authentication
  
  // Smart Publishing Configuration
  dailyLimit        Int      @default(7)       // Articles per day (starting limit)
  growthRate        Float    @default(0.10)    // Daily growth rate (10% = 0.10)
  maxDailyLimit     Int      @default(50)      // Growth ceiling — never exceeds this
  categories        String[] @default([])      // Categories to publish (empty = all)
  lastCategoryIndex Int      @default(0)       // For round-robin category rotation
  publishStartDay   DateTime @default(now())   // When to start counting days for growth
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  publishedArticles WebhookPublish[]
  registeredSite    RegisteredSite?
  
  @@map("webhooks")
}

// Track sites that self-registered via the WordPress plugin
model RegisteredSite {
  id           String   @id @default(uuid())
  domain       String   @unique              // e.g. "https://myblog.com"
  name         String
  tokenHash    String                        // SHA-256 of registration token (audit)
  status       String   @default("pending")  // pending, active, rejected
  registeredAt DateTime @default(now())
  approvedAt   DateTime?
  
  webhookId    String   @unique
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([domain])
  @@map("registered_sites")
}

// Track which articles have been sent to which webhooks
model WebhookPublish {
  id                  String   @id @default(uuid())
  
  webhookId           String
  webhook             Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  generatedArticleId  String
  generatedArticle    GeneratedArticle @relation(fields: [generatedArticleId], references: [id], onDelete: Cascade)
  
  category            String           // Category at time of publishing
  publishedAt         DateTime @default(now())
  status              String   @default("success") // success, failed
  
  @@unique([webhookId, generatedArticleId]) // Prevent duplicate publishing
  @@index([webhookId, publishedAt])
  @@index([webhookId, category])
  @@map("webhook_publishes")
}

