generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Source {
  id            String   @id @default(uuid())
  name          String
  feedUrl       String   @unique
  baseUrl       String?
  active        Boolean  @default(true)
  lastCheckedAt DateTime @default(now())
  totalArticles Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  articles      Article[]

  @@map("sources")
}

model Article {
  id           String   @id @default(uuid())
  url          String   @unique
  title        String
  excerpt      String?
  textContent  String?
  byline       String?
  siteName     String?
  status       String   @default("pending") // pending, scraped, failed
  errorMessage String?
  discoveredAt DateTime @default(now())
  scrapedAt    DateTime?
  embedding    Unsupported("vector(1536)")?
  
  sourceId     String
  source       Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  generatedArticle GeneratedArticle?

  @@index([url])
  @@index([status])
  @@index([sourceId])
  @@map("articles")
}

model GeneratedArticle {
  id          String   @id @default(uuid())
  articleId   String   @unique
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  title       String         // AI-generated title
  content     String         // AI-generated content
  category    String         // e.g., "Politics", "Sports", "Tech", "Entertainment"
  
  status      String   @default("pending") // pending, generated, failed
  errorMessage String?
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([status])
  @@map("generated_articles")
}

model Webhook {
  id          String   @id @default(uuid())
  name        String                          // e.g., "Production Blog", "Staging"
  url         String   @unique                // The webhook URL
  active      Boolean  @default(true)         // Enable/disable webhook
  secret      String?                         // Optional secret for authentication
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("webhooks")
}
